{
  "version": 1,
  "description": "Shared Rust/Python conformance corpus for request body integration behavior",
  "groups": {
    "body_policy_selection": {
      "description": "Body acceptance/rejection based on policy configuration",
      "fixtures": [
        {
          "id": "reject-policy-blocks-body",
          "description": "Reject policy returns 413 without invoking handler",
          "input": {
            "method": "POST",
            "body": "hello",
            "headers": { "Content-Length": "5" },
            "policy": "reject",
            "max_body_bytes": 1024
          },
          "expected": {
            "status": 413,
            "handler_called": false
          }
        },
        {
          "id": "buffer-policy-accepts-body",
          "description": "Buffer policy accepts POST with body",
          "input": {
            "method": "POST",
            "body": "hello",
            "headers": { "Content-Length": "5" },
            "policy": "buffer",
            "max_body_bytes": 1024
          },
          "expected": {
            "status": 200,
            "handler_called": true,
            "echo_body": "hello"
          }
        },
        {
          "id": "stream-policy-accepts-body",
          "description": "Stream policy accepts POST with body",
          "input": {
            "method": "POST",
            "body": "hello",
            "headers": { "Content-Length": "5" },
            "policy": "stream",
            "max_body_bytes": 1024
          },
          "expected": {
            "status": 200,
            "handler_called": true,
            "echo_body": "hello"
          }
        },
        {
          "id": "static-service-rejects-post",
          "description": "Static service returns 405 for POST",
          "input": {
            "method": "POST",
            "body": "hello",
            "headers": { "Content-Length": "5" },
            "policy": "static",
            "max_body_bytes": 1024
          },
          "expected": {
            "status": 405,
            "handler_called": false
          }
        }
      ]
    },
    "empty_body": {
      "description": "Empty and zero-length body handling",
      "fixtures": [
        {
          "id": "get-no-body",
          "description": "GET request has no body",
          "input": {
            "method": "GET",
            "body": null,
            "headers": {},
            "policy": "buffer",
            "max_body_bytes": 1024
          },
          "expected": {
            "status": 200,
            "has_body": false,
            "body_data": ""
          }
        },
        {
          "id": "post-content-length-zero",
          "description": "POST with Content-Length: 0 has empty body",
          "input": {
            "method": "POST",
            "body": "",
            "headers": { "Content-Length": "0" },
            "policy": "buffer",
            "max_body_bytes": 1024
          },
          "expected": {
            "status": 200,
            "has_body": true,
            "body_data": ""
          }
        },
        {
          "id": "post-empty-body",
          "description": "POST with no body data",
          "input": {
            "method": "POST",
            "body": "",
            "headers": {},
            "policy": "buffer",
            "max_body_bytes": 1024
          },
          "expected": {
            "status": 200,
            "has_body": true,
            "body_data": ""
          }
        }
      ]
    },
    "fixed_length_exact": {
      "description": "Fixed-length body within limit",
      "fixtures": [
        {
          "id": "fixed-small",
          "description": "Small fixed-length body within limit",
          "input": {
            "method": "POST",
            "body": "hello",
            "headers": { "Content-Length": "5" },
            "policy": "buffer",
            "max_body_bytes": 1024
          },
          "expected": {
            "status": 200,
            "echo_body": "hello"
          }
        },
        {
          "id": "fixed-unicode",
          "description": "Unicode fixed-length body",
          "input": {
            "method": "POST",
            "body": "hello \u00e9\u00e8\u00ea",
            "headers": { "Content-Length": "12" },
            "policy": "buffer",
            "max_body_bytes": 1024
          },
          "expected": {
            "status": 200,
            "echo_body": "hello \u00e9\u00e8\u00ea"
          }
        },
        {
          "id": "fixed-binary",
          "description": "Binary fixed-length body",
          "input": {
            "method": "POST",
            "body_hex": "00010203040506070809",
            "headers": { "Content-Length": "10" },
            "policy": "buffer",
            "max_body_bytes": 1024
          },
          "expected": {
            "status": 200,
            "echo_len": 10
          }
        },
        {
          "id": "fixed-exact-limit",
          "description": "Body exactly at the limit",
          "input": {
            "method": "POST",
            "body": "12345",
            "headers": { "Content-Length": "5" },
            "policy": "buffer",
            "max_body_bytes": 5
          },
          "expected": {
            "status": 200,
            "echo_body": "12345"
          }
        }
      ]
    },
    "fixed_length_premature_eof": {
      "description": "Fixed-length body with premature connection close",
      "fixtures": [
        {
          "id": "premature-eof-missing-bytes",
          "description": "Connection closes before declared Content-Length is fully sent",
          "input": {
            "method": "POST",
            "body_partial": "hel",
            "headers": { "Content-Length": "5" },
            "policy": "buffer",
            "max_body_bytes": 1024
          },
          "expected": {
            "status": 400,
            "handler_called": false
          }
        }
      ]
    },
    "fixed_length_over_limit": {
      "description": "Fixed-length body exceeding configured limit",
      "fixtures": [
        {
          "id": "over-limit-fixed",
          "description": "Body exceeds max_request_body_bytes",
          "input": {
            "method": "POST",
            "body": "xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx",
            "headers": { "Content-Length": "100" },
            "policy": "buffer",
            "max_body_bytes": 5
          },
          "expected": {
            "status": 413,
            "handler_called": false
          }
        },
        {
          "id": "declared-length-over-limit",
          "description": "Declared Content-Length exceeds limit before body is sent",
          "input": {
            "method": "POST",
            "body": "",
            "headers": { "Content-Length": "100000" },
            "policy": "buffer",
            "max_body_bytes": 5
          },
          "expected": {
            "status": 413,
            "handler_called": false
          }
        }
      ]
    },
    "chunked_exact": {
      "description": "Chunked transfer-encoding body within limit",
      "fixtures": [
        {
          "id": "chunked-single-chunk",
          "description": "Single chunk within limit",
          "input": {
            "method": "POST",
            "body": "hello",
            "encoding": "chunked",
            "policy": "stream",
            "max_body_bytes": 1024
          },
          "expected": {
            "status": 200,
            "echo_body": "hello"
          }
        },
        {
          "id": "chunked-multi-chunk",
          "description": "Multiple chunks reassembled",
          "input": {
            "method": "POST",
            "body": "hello world",
            "encoding": "chunked",
            "chunk_size": 5,
            "policy": "stream",
            "max_body_bytes": 1024
          },
          "expected": {
            "status": 200,
            "echo_body": "hello world"
          }
        }
      ]
    },
    "chunked_many_small_chunks": {
      "description": "Chunked body with many small chunks",
      "fixtures": [
        {
          "id": "chunked-single-byte-chunks",
          "description": "Many single-byte chunks",
          "input": {
            "method": "POST",
            "body": "abcdef",
            "encoding": "chunked",
            "chunk_size": 1,
            "policy": "stream",
            "max_body_bytes": 1024
          },
          "expected": {
            "status": 200,
            "echo_body": "abcdef"
          }
        }
      ]
    },
    "chunked_over_limit": {
      "description": "Chunked body exceeding the decoded-size limit",
      "fixtures": [
        {
          "id": "chunked-over-limit",
          "description": "Chunked body total exceeds max_bytes (handler reads body, hits limit)",
          "input": {
            "method": "POST",
            "body": "xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx",
            "encoding": "chunked",
            "chunk_size": 10,
            "policy": "stream",
            "max_body_bytes": 5
          },
          "expected": {
            "status": 413,
            "handler_called": true
          }
        }
      ]
    },
    "one_shot_consumption": {
      "description": "Body can only be consumed once",
      "fixtures": [
        {
          "id": "double-read-ok-at-rust-level",
          "description": "Rust next_chunk can be called multiple times (one-shot is Python-level)",
          "input": {
            "method": "POST",
            "body": "data",
            "headers": { "Content-Length": "4" },
            "policy": "buffer",
            "max_body_bytes": 1024,
            "handler_action": "double_read"
          },
          "expected": {
            "status": 200,
            "handler_called": true
          }
        }
      ]
    },
    "get_with_body_rejected": {
      "description": "GET requests with body are rejected at HTTP level",
      "fixtures": [
        {
          "id": "get-with-content-length",
          "description": "GET with Content-Length header and body",
          "input": {
            "method": "GET",
            "body": "hello",
            "headers": { "Content-Length": "5" },
            "policy": "buffer",
            "max_body_bytes": 1024
          },
          "expected": {
            "status": 400,
            "handler_called": false
          }
        }
      ]
    },
    "conflicting_content_length": {
      "description": "Conflicting Content-Length values are rejected at the HTTP/1 wire level",
      "fixtures": [
        {
          "id": "two-different-content-lengths",
          "description": "Two Content-Length headers with different values → 400 (Hyper rejects at wire level)",
          "input": {
            "method": "POST",
            "body": "hello",
            "headers": {
              "Content-Length": "5",
              "X-Extra-Content-Length": "10"
            },
            "policy": "buffer",
            "max_body_bytes": 1024,
            "extra_raw_headers": "Content-Length: 10\r\n"
          },
          "expected": {
            "status": 400,
            "handler_called": false,
            "connection_closed": true
          }
        },
        {
          "id": "two-identical-content-lengths",
          "description": "Two Content-Length headers with same value → 200 (Hyper normalizes identical duplicates at wire level)",
          "input": {
            "method": "POST",
            "body": "hello",
            "headers": {
              "Content-Length": "5"
            },
            "policy": "buffer",
            "max_body_bytes": 1024,
            "extra_raw_headers": "Content-Length: 5\r\n"
          },
          "expected": {
            "status": 200,
            "handler_called": true,
            "echo_body": "hello"
          }
        }
      ]
    },
    "te_plus_content_length_conflict": {
      "description": "Requests with both Transfer-Encoding and Content-Length are rejected",
      "fixtures": [
        {
          "id": "te-and-cl-both-present",
          "description": "Transfer-Encoding: chunked + Content-Length → 400 Bad Request",
          "input": {
            "method": "POST",
            "body": "chunked-wins",
            "encoding": "chunked",
            "headers": { "Content-Length": "12" },
            "policy": "stream",
            "max_body_bytes": 1024
          },
          "expected": {
            "status": 400,
            "handler_called": false,
            "connection_closed": true
          }
        }
      ]
    },
    "te_plus_cl_variants": {
      "description": "Additional TE+CL rejection edge cases",
      "fixtures": [
        {
          "id": "te-chunked-plus-single-cl",
          "description": "Transfer-Encoding: chunked + single Content-Length → 400",
          "input": {
            "method": "POST",
            "body": "data",
            "encoding": "chunked",
            "headers": { "Content-Length": "4" },
            "policy": "stream",
            "max_body_bytes": 1024
          },
          "expected": {
            "status": 400,
            "handler_called": false,
            "connection_closed": true
          }
        },
        {
          "id": "te-chunked-plus-duplicate-identical-cl",
          "description": "Transfer-Encoding: chunked + two identical Content-Length → 400",
          "input": {
            "method": "POST",
            "body": "data",
            "encoding": "chunked",
            "headers": { "Content-Length": "4" },
            "policy": "stream",
            "max_body_bytes": 1024,
            "extra_raw_headers": "Content-Length: 4\r\n"
          },
          "expected": {
            "status": 400,
            "handler_called": false,
            "connection_closed": true
          }
        },
        {
          "id": "te-chunked-plus-conflicting-cl",
          "description": "Transfer-Encoding: chunked + two different Content-Length → 400",
          "input": {
            "method": "POST",
            "body": "data",
            "encoding": "chunked",
            "headers": { "Content-Length": "4" },
            "policy": "stream",
            "max_body_bytes": 1024,
            "extra_raw_headers": "Content-Length: 99\r\n"
          },
          "expected": {
            "status": 400,
            "handler_called": false,
            "connection_closed": true
          }
        }
      ]
    },
    "chunked_malformed": {
      "description": "Malformed chunked transfer-encoding is rejected",
      "fixtures": [
        {
          "id": "missing-chunk-terminator",
          "description": "Chunk missing final 0-length terminator → body timeout (408 or 504)",
          "input": {
            "method": "POST",
            "body": "hello",
            "encoding": "chunked_no_terminator",
            "policy": "stream",
            "max_body_bytes": 1024
          },
          "expected": {
            "status": 504,
            "handler_called": true
          }
        }
      ]
    },
    "chunked_exact_limit": {
      "description": "Chunked body at exact limit and one byte over",
      "fixtures": [
        {
          "id": "chunked-exact-limit",
          "description": "Chunked body total equals max_bytes → 200",
          "input": {
            "method": "POST",
            "body": "12345",
            "encoding": "chunked",
            "chunk_size": 5,
            "policy": "stream",
            "max_body_bytes": 5
          },
          "expected": {
            "status": 200,
            "echo_body": "12345"
          }
        },
        {
          "id": "chunked-one-over-limit",
          "description": "Chunked body total is one byte over max_bytes → 413",
          "input": {
            "method": "POST",
            "body": "123456",
            "encoding": "chunked",
            "chunk_size": 6,
            "policy": "stream",
            "max_body_bytes": 5
          },
          "expected": {
            "status": 413,
            "handler_called": true
          }
        }
      ]
    },
    "buffer_mode": {
      "description": "Buffer mode reads entire body into memory before handler invocation",
      "fixtures": [
        {
          "id": "buffer-read-all",
          "description": "Buffer mode provides full body via read()",
          "input": {
            "method": "POST",
            "body": "buffered data",
            "headers": { "Content-Length": "12" },
            "policy": "buffer",
            "max_body_bytes": 1024,
            "handler_action": "read_all"
          },
          "expected": {
            "status": 200,
            "handler_called": true,
            "echo_body": "buffered data"
          }
        },
        {
          "id": "buffer-empty",
          "description": "Buffer mode with empty body returns empty bytes",
          "input": {
            "method": "POST",
            "body": "",
            "headers": { "Content-Length": "0" },
            "policy": "buffer",
            "max_body_bytes": 1024,
            "handler_action": "read_all"
          },
          "expected": {
            "status": 200,
            "handler_called": true
          }
        }
      ]
    },
    "stream_mode": {
      "description": "Stream mode delivers body in chunks via next_chunk",
      "fixtures": [
        {
          "id": "stream-chunked-delivery",
          "description": "Stream mode delivers chunked body via iteration",
          "input": {
            "method": "POST",
            "body": "streamed data",
            "encoding": "chunked",
            "chunk_size": 6,
            "policy": "stream",
            "max_body_bytes": 1024,
            "handler_action": "stream_collect"
          },
          "expected": {
            "status": 200,
            "handler_called": true,
            "echo_body": "streamed data"
          }
        },
        {
          "id": "stream-fixed-length",
          "description": "Stream mode also works with fixed-length body",
          "input": {
            "method": "POST",
            "body": "fixed via stream",
            "headers": { "Content-Length": "15" },
            "policy": "stream",
            "max_body_bytes": 1024,
            "handler_action": "stream_collect"
          },
          "expected": {
            "status": 200,
            "handler_called": true,
            "echo_body": "fixed via stream"
          }
        }
      ]
    },
    "mixed_read_iteration": {
      "description": "Body consumption mode consistency — typed failure expected for mixed consumption",
      "fixtures": [
        {
          "id": "read-then-iterate-fails",
          "description": "After read_all, iteration returns typed error (not silent empty data)",
          "input": {
            "method": "POST",
            "body": "data",
            "headers": { "Content-Length": "4" },
            "policy": "buffer",
            "max_body_bytes": 1024,
            "handler_action": "read_then_iter"
          },
          "expected": {
            "status": 200,
            "handler_called": true
          }
        },
        {
          "id": "iterate-then-read-fails",
          "description": "After full iteration, read returns typed error (not silent empty data)",
          "input": {
            "method": "POST",
            "body": "data",
            "headers": { "Content-Length": "4" },
            "policy": "buffer",
            "max_body_bytes": 1024,
            "handler_action": "double_iter"
          },
          "expected": {
            "status": 200,
            "handler_called": true
          }
        }
      ]
    },
    "partial_consumption_close": {
      "description": "Partial body consumption with Close policy closes connection",
      "fixtures": [
        {
          "id": "partial-read-close",
          "description": "Buffer mode: partial application read leaves no unread transport bytes; connection remains reusable",
          "input": {
            "method": "POST",
            "body": "partial data here",
            "headers": { "Content-Length": "17" },
            "policy": "buffer",
            "max_body_bytes": 1024,
            "handler_action": "partial_read"
          },
          "expected": {
            "status": 200,
            "handler_called": true
          }
        }
      ]
    },
    "partial_consumption_stream": {
      "description": "Stream-specific partial consumption scenarios (object consumption vs transport consumption)",
      "fixtures": [
        {
          "id": "stream-partial-close",
          "description": "Stream mode: partial consumption with Close policy, connection closes after response",
          "input": {
            "method": "POST",
            "body": "stream partial data",
            "encoding": "chunked",
            "chunk_size": 6,
            "policy": "stream",
            "max_body_bytes": 1024,
            "handler_action": "partial_read"
          },
          "expected": {
            "status": 200,
            "handler_called": true
          }
        },
        {
          "id": "stream-full-consumption-keepalive",
          "description": "Stream mode: full consumption preserves keep-alive",
          "input": {
            "method": "POST",
            "body": "full stream data",
            "encoding": "chunked",
            "chunk_size": 5,
            "policy": "stream",
            "max_body_bytes": 1024,
            "handler_action": "stream_collect"
          },
          "expected": {
            "status": 200,
            "handler_called": true,
            "echo_body": "full stream data"
          }
        },
        {
          "id": "stream-drop-body-early",
          "description": "Stream mode: handler returns without reading body, connection closes",
          "input": {
            "method": "POST",
            "body": "unread data",
            "encoding": "chunked",
            "chunk_size": 6,
            "policy": "stream",
            "max_body_bytes": 1024,
            "handler_action": "drop_body"
          },
          "expected": {
            "status": 200,
            "handler_called": true
          }
        }
      ]
    },
    "content_length_edge_cases": {
      "description": "Content-Length header edge cases (Hyper normalizes most malformed values at wire level)",
      "fixtures": [
        {
          "id": "cl-leading-zeros",
          "description": "Content-Length with leading zeros is normalized by Hyper",
          "input": {
            "method": "POST",
            "body": "hello",
            "headers": { "Content-Length": "005" },
            "policy": "buffer",
            "max_body_bytes": 1024
          },
          "expected": {
            "status": 200,
            "handler_called": true,
            "echo_body": "hello"
          }
        },
        {
          "id": "cl-with-ows",
          "description": "Content-Length with optional whitespace is normalized by Hyper",
          "input": {
            "method": "POST",
            "body": "hello",
            "headers": { "Content-Length": "  5  " },
            "policy": "buffer",
            "max_body_bytes": 1024
          },
          "expected": {
            "status": 200,
            "handler_called": true,
            "echo_body": "hello"
          }
        },
        {
          "id": "cl-zero-length",
          "description": "Content-Length: 0 is valid and produces empty body",
          "input": {
            "method": "POST",
            "body": "",
            "headers": { "Content-Length": "0" },
            "policy": "buffer",
            "max_body_bytes": 1024
          },
          "expected": {
            "status": 200,
            "handler_called": true
          }
        }
      ]
    },
    "malformed_content_length": {
      "description": "Content-Length values rejected at HTTP/1 wire level by Hyper (documented for completeness)",
      "note": "These cases are rejected by Hyper before eggserve processes them. They cannot be tested through the normal HTTP pipeline. This group documents the expected wire-level behavior.",
      "fixtures": [
        {
          "id": "cl-empty-value",
          "description": "Content-Length: '' — Hyper rejects at wire level → 400",
          "impossible_through_pipeline": true,
          "input": {
            "method": "POST",
            "body": "",
            "headers": {},
            "policy": "buffer",
            "max_body_bytes": 1024,
            "extra_raw_headers": "Content-Length: \r\n"
          },
          "expected": {
            "status": 400,
            "handler_called": false
          }
        },
        {
          "id": "cl-negative-value",
          "description": "Content-Length: -1 — Hyper rejects at wire level → 400",
          "impossible_through_pipeline": true,
          "input": {
            "method": "POST",
            "body": "",
            "headers": {},
            "policy": "buffer",
            "max_body_bytes": 1024,
            "extra_raw_headers": "Content-Length: -1\r\n"
          },
          "expected": {
            "status": 400,
            "handler_called": false
          }
        },
        {
          "id": "cl-hex-value",
          "description": "Content-Length: 0x0A — Hyper rejects non-decimal at wire level → 400",
          "impossible_through_pipeline": true,
          "input": {
            "method": "POST",
            "body": "",
            "headers": {},
            "policy": "buffer",
            "max_body_bytes": 1024,
            "extra_raw_headers": "Content-Length: 0x0A\r\n"
          },
          "expected": {
            "status": 400,
            "handler_called": false
          }
        },
        {
          "id": "cl-signed-plus",
          "description": "Content-Length: +5 — Hyper rejects signed value at wire level → 400",
          "impossible_through_pipeline": true,
          "input": {
            "method": "POST",
            "body": "",
            "headers": {},
            "policy": "buffer",
            "max_body_bytes": 1024,
            "extra_raw_headers": "Content-Length: +5\r\n"
          },
          "expected": {
            "status": 400,
            "handler_called": false
          }
        },
        {
          "id": "cl-overflow",
          "description": "Content-Length: 18446744073709551616 — Hyper rejects overflow at wire level → 400",
          "impossible_through_pipeline": true,
          "input": {
            "method": "POST",
            "body": "",
            "headers": {},
            "policy": "buffer",
            "max_body_bytes": 1024,
            "extra_raw_headers": "Content-Length: 18446744073709551616\r\n"
          },
          "expected": {
            "status": 400,
            "handler_called": false
          }
        },
        {
